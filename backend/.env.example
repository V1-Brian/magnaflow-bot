# Database
DATABASE_URL=postgresql://user:password@host:5432/magnaflow_bot

# Claude
ANTHROPIC_API_KEY=your_key_here

# Cloudflare KV
CF_ACCOUNT_ID=your_account_id
CF_KV_NAMESPACE_ID=your_namespace_id
CF_API_TOKEN=your_token

# ElevenLabs (voice)
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_chosen_voice_id

# Twilio (voice)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Optional: Vapi (if using instead of Twilio + ElevenLabs)
VAPI_API_KEY=your_key_here

# Public base URL (for serving ElevenLabs audio to Twilio)
PUBLIC_BASE_URL=https://your-render-service.onrender.com

PORT=3001
